# ── Copy to terraform.tfvars and fill in your values ─────────────────────────

# Proxmox
proxmox_endpoint             = "https://192.168.1.10:8006"
proxmox_api_token            = "terraform@pve!terraform-token=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_insecure             = true
proxmox_node                 = "pve"
proxmox_ssh_username         = "root"
proxmox_ssh_private_key_path = "~/.ssh/id_rsa"

# Ubuntu cloud-init template (create with scripts/build-template.sh or manually)
template_vm_id = 9000

# VM IDs: cp-1=200, cp-2=201, cp-3=202, worker-1=203, worker-2=204, worker-3=205
vm_id_base     = 200
datastore      = "local-lvm"
network_bridge = "vmbr0"

# Networking
# Results in: cp-1=192.168.1.11, cp-2=192.168.1.12, cp-3=192.168.1.13
#             worker-1=192.168.1.21, worker-2=192.168.1.22, worker-3=192.168.1.23
#             VIP=192.168.1.10
base_network       = "192.168.1"
network_prefix     = 24
network_gateway    = "192.168.1.1"
dns_server         = "8.8.8.8"
control_plane_vip  = "192.168.1.10"
cp_ip_start        = 11
worker_ip_start    = 21

# SSH key injected into VMs
ssh_public_key          = "ssh-rsa AAAAB3Nza... your-key-here"
vm_ssh_private_key_path = "~/.ssh/id_rsa"

# Control plane sizing
cp_cores     = 2
cp_memory_mb = 4096
cp_disk_gb   = 50

# Worker sizing
worker_cores     = 4
worker_memory_mb = 8192
worker_disk_gb   = 100

# Kubernetes
kubernetes_version = "1.31"
pod_cidr           = "192.168.0.0/16"
service_cidr       = "10.96.0.0/12"
calico_version     = "3.29.0"
